<!--
  sitemap.xml — Update URLs and lastmod dates before deploying.

  For dynamic content (blog posts, products, etc.), generate this file
  at build time using a script or a sitemap library (e.g. vite-plugin-sitemap).

  Validator: https://www.xml-sitemaps.com/validate-xml-sitemap.html
-->
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9"
        xmlns:xhtml="http://www.w3.org/1999/xhtml">

  <url>
    <loc>https://example.com/</loc>
    <lastmod>2026-06-28</lastmod>
    <changefreq>weekly</changefreq>
    <priority>1.0</priority>
  </url>

  <url>
    <loc>https://example.com/about</loc>
    <lastmod>2026-06-28</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.8</priority>
  </url>

  <!--
  Add more routes below. For React Router SPA routes, add each
  client-side route that should be crawlable as a separate <url>.

  <url>
    <loc>https://example.com/features</loc>
    <lastmod>2026-06-28</lastmod>
    <changefreq>monthly</changefreq>
    <priority>0.7</priority>
  </url>
  -->

</urlset>
