HOST=0.0.0.0
PORT=1337

# Generate with: openssl rand -base64 32 (run 4 times for each key)
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# sqlite (local dev) | postgres (docker/production)
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Postgres (when DATABASE_CLIENT=postgres)
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/wikiwonder_strapi
# DATABASE_SSL=false

# CORS — allow Next.js dev/prod origins
CORS_ORIGIN=http://localhost:9000,http://127.0.0.1:9000

# GraphQL
STRAPI_GRAPHQL_V4_COMPATIBILITY_MODE=false
