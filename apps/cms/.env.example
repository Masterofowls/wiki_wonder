HOST=0.0.0.0
PORT=1337

# Generate with: openssl rand -base64 32 (run 4 times for APP_KEYS)
APP_KEYS=toBeModified1,toBeModified2,toBeModified3,toBeModified4
API_TOKEN_SALT=tobemodified
ADMIN_JWT_SECRET=tobemodified
TRANSFER_TOKEN_SALT=tobemodified
JWT_SECRET=tobemodified

# Local: sqlite | Production (Render + Neon): postgres
DATABASE_CLIENT=sqlite
DATABASE_FILENAME=.tmp/data.db

# Neon Postgres (Render production — use pooled URL from Neon dashboard)
# DATABASE_CLIENT=postgres
# DATABASE_URL=postgresql://USER:PASSWORD@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
# DATABASE_SSL=true

# Allowed wiki frontend origins (comma-separated)
CORS_ORIGIN=http://localhost:9000,https://wikiwonder.vercel.app

# Realtime wiki updates — Strapi calls Next.js on publish
REVALIDATE_URL=https://wikiwonder.vercel.app/api/revalidate
REVALIDATE_SECRET=generate-a-shared-secret

# Public CMS URL (for admin links)
STRAPI_PUBLIC_URL=https://wikiwonder-cms.onrender.com

STRAPI_GRAPHQL_V4_COMPATIBILITY_MODE=false
