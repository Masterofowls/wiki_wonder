{
  "extends": "../../packages/config/tsconfig/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@wikiwonder/ui": [
        "../../packages/ui/src/index.ts"
      ],
      "@wikiwonder/utils": [
        "../../packages/utils/src/index.ts"
      ],
      "@wikiwonder/db": [
        "../../packages/db/src/index.ts"
      ],
      "@wikiwonder/wiki-core": [
        "../../packages/wiki-core/src/index.ts"
      ],
      "@wikiwonder/wiki-core/import": [
        "../../packages/wiki-core/src/import.ts"
      ]
    },
    "allowJs": true
  },
  "include": [
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
