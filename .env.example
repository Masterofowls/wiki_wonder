# ─── App ─────────────────────────────────────────────────────────
# NODE_ENV is set automatically by the runtime; override here only
# if you need to force a specific environment.
NODE_ENV=development

# Public URL for the app (used in Open Graph, canonical URLs, etc.)
APP_URL=http://localhost:9000
APP_PORT=9000

# ─── Next.js Web App ─────────────────────────────────────────────
# NEXT_PUBLIC_* vars are inlined at build time — do NOT put secrets here.
NEXT_PUBLIC_APP_URL=http://localhost:9000
NEXT_PUBLIC_API_URL=http://localhost:9000/api
NEXT_PUBLIC_APP_NAME="My App"
NEXT_PUBLIC_APP_DESCRIPTION="A production-grade TypeScript React application"
NEXT_PUBLIC_ENABLE_ANALYTICS=false

# ─── Vite SPA ────────────────────────────────────────────────────
# VITE_* vars are inlined at build time — do NOT put secrets here.
VITE_API_URL=http://localhost:9000/api
VITE_APP_NAME="My App"
VITE_APP_DESCRIPTION="A production-grade TypeScript React application"
VITE_ENABLE_DEBUG=true

# ─── Database (optional — remove if unused) ──────────────────────
# DATABASE_URL=postgresql://user:password@localhost:5432/mydb
# DATABASE_POOL_SIZE=10
# DATABASE_SSL=false

# ─── Auth (optional — remove if unused) ──────────────────────────
# JWT_SECRET=replace-with-a-secure-random-secret-at-least-32-chars
# JWT_EXPIRY=7d
# REFRESH_TOKEN_SECRET=replace-with-another-secure-random-secret

# ─── Redis / Cache (optional — remove if unused) ─────────────────
# REDIS_URL=redis://localhost:6379
# REDIS_TTL=3600

# ─── Email (optional — remove if unused) ─────────────────────────
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=noreply@example.com
# SMTP_PASS=your-smtp-password
# EMAIL_FROM="My App <noreply@example.com>"

# ─── Object Storage (optional — remove if unused) ────────────────
# S3_BUCKET=your-s3-bucket
# S3_REGION=us-east-1
# S3_ACCESS_KEY=your-access-key
# S3_SECRET_KEY=your-secret-key
# S3_ENDPOINT=https://s3.amazonaws.com

# ─── Observability (optional) ────────────────────────────────────
# SENTRY_DSN=
LOG_LEVEL=debug
# ENABLE_METRICS=false

# ─── CVE Lite CLI ────────────────────────────────────────────────
CVE_SCAN_PATH=.
CVE_OSV_API=https://api.osv.dev/v1
CVE_FAIL_ON_HIGH=true
CVE_OUTPUT_FORMAT=table

# ─── Index Check CLI ─────────────────────────────────────────────
INDEX_CHECK_PATH=.
INDEX_CHECK_EXTENSIONS=ts,tsx
INDEX_CHECK_AUTO_FIX=false
