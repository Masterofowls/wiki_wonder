# WikiWonder — Environment Variables
# Copy to .env.local (local) or set in Vercel Project Settings → Environment Variables

# ─── App ─────────────────────────────────────────────────────────
NODE_ENV=development
APP_URL=http://localhost:9000
APP_PORT=9000

# ─── Next.js Web App (NEXT_PUBLIC_* = build-time, safe for client) ─
NEXT_PUBLIC_APP_URL=http://localhost:9000
NEXT_PUBLIC_API_URL=http://localhost:9000/api
NEXT_PUBLIC_APP_NAME="WikiWonder"
NEXT_PUBLIC_APP_DESCRIPTION="Advanced Modern Wiki with instant search, rich markdown, and offline PWA"
NEXT_PUBLIC_AUTHOR=""
NEXT_PUBLIC_ENABLE_ANALYTICS=false
NEXT_PUBLIC_ENABLE_SW=true
NEXT_PUBLIC_ENABLE_REACT_SCAN=false

# ─── Vercel Production (set in Vercel dashboard) ────────────────
# NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
# AUTH_URL=https://your-app.vercel.app

# ─── Database (Supabase Postgres via Drizzle) ─────────────────────
# DATABASE_URL=postgresql://postgres:password@db.xxxxx.supabase.co:5432/postgres
DATABASE_POOL_SIZE=10
DATABASE_SSL=true

# ─── Auth (NextAuth — username/password, no email) ───────────────
# Required on Vercel — generate: openssl rand -base64 32
# AUTH_SECRET=replace-with-a-secure-random-secret-at-least-32-chars
# AUTH_URL=http://localhost:9000

# ─── Strapi CMS (GraphQL) ────────────────────────────────────────
# Local: http://localhost:1337/graphql
# Production: https://your-strapi.onrender.com/graphql
# STRAPI_GRAPHQL_URL=http://localhost:1337/graphql
# STRAPI_API_TOKEN=create-in-strapi-admin-settings-api-tokens

# ─── Supabase (optional client SDK) ─────────────────────────────
# NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ─── Observability ───────────────────────────────────────────────
LOG_LEVEL=debug

# ─── CVE Lite CLI ────────────────────────────────────────────────
CVE_SCAN_PATH=.
CVE_OSV_API=https://api.osv.dev/v1
CVE_FAIL_ON_HIGH=true
CVE_OUTPUT_FORMAT=table

# ─── Index Check CLI ─────────────────────────────────────────────
INDEX_CHECK_PATH=.
INDEX_CHECK_EXTENSIONS=ts,tsx
INDEX_CHECK_AUTO_FIX=false
