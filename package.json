{
  "name": "my-app",
  "version": "0.1.0",
  "private": true,
  "description": "A production-grade TypeScript React fullstack monorepo",
  "workspaces": ["apps/*", "packages/*", "tools/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:web": "bun run --filter './apps/web' dev",
    "dev:spa": "bun run --filter './apps/spa' dev",
    "build": "bun run --filter '*' build",
    "build:web": "bun run --filter './apps/web' build",
    "build:spa": "bun run --filter './apps/spa' build",
    "test": "jest --passWithNoTests",
    "test:unit": "jest tests/unit --passWithNoTests",
    "test:integration": "jest tests/integration --passWithNoTests",
    "test:e2e": "playwright test",
    "test:watch": "jest --watch",
    "typecheck": "bun run --filter '*' typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome lint --write .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:fix": "biome check --write .",
    "cve": "bun run tools/cve-lite/src/cli.ts",
    "index-check": "bun run tools/index-check/src/cli.ts",
    "lint:css": "stylelint \"**/*.css\" --allow-empty-input",
    "lint:css:fix": "stylelint \"**/*.css\" --fix --allow-empty-input",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "deps:check": "ncu --workspaces --root",
    "deps:update": "ncu --workspaces --root --upgrade",
    "deps:taze": "taze",
    "deps:taze:write": "taze --write",
    "init": "bash scripts/init.sh",
    "setup": "bash scripts/setup.sh",
    "clean": "find . -name 'node_modules' -type d -prune -exec rm -rf '{}' + ; find . -name '.next' -type d -prune -exec rm -rf '{}' + ; find . -name 'dist' -type d -prune -exec rm -rf '{}' +"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@jest/globals": "^30.4.1",
    "@playwright/test": "^1.49.1",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.7",
    "jest": "^29.7.0",
    "knip": "^6.23.0",
    "npm-check-updates": "^22.2.8",
    "react-scan": "^0.5.7",
    "stylelint": "^17.14.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "taze": "^19.14.1",
    "ts-jest": "^29.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.3"
  },
  "engines": {
    "bun": ">=1.1.0",
    "node": ">=20.0.0"
  }
}
